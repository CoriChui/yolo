  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/yolo-cli/hook-pre-bash.sh",
            "statusMessage": "Gating bash writes..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/yolo-cli/hook-pre-write.sh",
            "statusMessage": "Checking edit against plan scope..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/yolo-cli/hook-post-write.sh",
            "statusMessage": "Checking test file modifications..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash scripts/yolo-cli/active-feature.sh --format status"
  }
}
